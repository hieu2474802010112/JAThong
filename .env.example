# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE (PRODUCTION-READY)
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit the '.env' file containing real secrets to version control.
# ==============================================================================

# Google Gemini API Configuration
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSyYourActualAPIKeyHere

# Optional Configuration Overrides
# Default model to use for CV evaluation
GEMINI_MODEL=gemini-1.5-flash

# System Instruction Prompt Version File
PROMPT_VERSION=cv_evaluator_v1.txt